# Copy to `.env.local` for local development.
#
# For dev on Mac against the serrano backend:
#   ssh -fN -L 8420:127.0.0.1:8420 serrano
# (backend binds localhost-only on serrano; tunnel exposes it on Mac's loopback)
#
# Then set:
NEXT_PUBLIC_DELAMAIN_API_BASE=http://127.0.0.1:8420/api

# Force sample-data mode regardless of backend reachability:
# NEXT_PUBLIC_DELAMAIN_MOCK=1

# Production (behind nginx on term.danielju.com): leave unset.
# The default is `/api` (same-origin), which nginx routes to FastAPI.
